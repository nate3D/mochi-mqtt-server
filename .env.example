# IP address assigned to this container on the macvlan network.
BROKER_IPV4=192.168.x.x

# Broker authentication
# Generate password hash: go run ./cmd/genhash <yourpassword> (escape $ as $$ in .env file)
BROKER_USERNAME=yourusername
BROKER_PASSWORD_HASH=$$2a$$12$$replacethiswithyourownhash

# Log verbosity: DEBUG (default), INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# Traefik configuration
TRAEFIK_INSTANCE=external
TRAEFIK_DOMAIN=mqtt.yourdomain.com
TRAEFIK_DOMAIN_ALT=mqtt.otherdomain.com
TRAEFIK_MQTT_ENTRYPOINT=mqtt
TRAEFIK_CERT_RESOLVER=tlsresolver
